# ─────────────────────────────────────────────────────────────
# PiukyFlix — variables d'environnement
# Copiez ce fichier en `.env` et renseignez les valeurs.
# Sur Replit, ces variables sont gérées via Secrets / Auth pane.
# ─────────────────────────────────────────────────────────────

# Base de données PostgreSQL (REQUIS)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Clerk — authentification (REQUIS)
# Backend
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Frontend (exposé au navigateur par Vite)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# Optionnel : URL du proxy Clerk (custom domains / Replit)
# VITE_CLERK_PROXY_URL=

# Resend — envoi des e-mails d'invitation (REQUIS pour les invitations)
RESEND_API_KEY=re_xxx

# Replit Object Storage — stockage de fichiers (REQUIS si l'upload est utilisé)
PUBLIC_OBJECT_SEARCH_PATHS=/bucket/public
PRIVATE_OBJECT_DIR=/bucket/.private

# Hôtes publics du déploiement, séparés par des virgules.
# Alimente l'allowlist CORS et les liens dans les e-mails.
REPLIT_DOMAINS=mon-app.replit.app

# E-mails promus admin à la connexion (optionnel, séparés par des virgules)
ADMIN_EMAILS=admin@exemple.com

# Divers (optionnel)
# NODE_ENV=development
# LOG_LEVEL=info
# PORT=8080
